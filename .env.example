# ---------------------------------------------------------------------------
# Overly-Engineered TODO — environment configuration example.
# Copy this file to `.env` and adjust as needed. Every configurable value the
# application reads is documented here.
# ---------------------------------------------------------------------------

# Cryptographic signing key for Django. In production, set a long random value.
# NOTE: with DJANGO_DEBUG=False the app refuses to start while this is left at the
# insecure development default (boot guard) — set a strong, unique key first, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=dev-insecure-change-me-0123456789abcdef

# Toggle debug mode. Never enable in production.
DJANGO_DEBUG=True

# Comma-separated list of hostnames permitted to serve the app.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Log level for the application's structured logger.
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
APP_LOG_LEVEL=INFO

# --- Feature flags -----------------------------------------------------------
# Persist every domain event to the database for a full audit trail.
FEATURE_EVENT_SOURCING=True
# Emit a structured log line for each domain event as it is published.
FEATURE_EVENT_LOGGING=True
# Enforce the task lifecycle state machine on status transitions.
FEATURE_STRICT_STATE_MACHINE=True
